# customer-service-gateway environment variables
#
# When running via docker-compose, values in docker-compose.yml override these.
# When running with `node dist/index.js` on the host, dotenv loads this file
# (after you copy it to .env).

# Port the Express server listens on.
GATEWAY_PORT=3100

# Upstream URL the gateway proxies /api/helpdesk/* to.
# The gateway strips /api/helpdesk and appends the rest to this URL.
#
# Default for local docker integration (gateway in docker on integration_net,
# webapp_core fresh stack on integration_net):
HELPDESK_API_URL=http://webapp_core_nginx_fresh:80/helpdesk/api
#
# Alternative for host-side dev (Laravel artisan serve on host port 8000):
# HELPDESK_API_URL=http://localhost:8000/helpdesk/api

# Comma-separated CORS origins. Empty = wildcard. Match what your frontend uses.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080,http://localhost:8443

# Pilot-routing targets for sidecar microservices. Leave commented to use the
# defaults baked into src/index.ts (cs-tickets / cs-kb / cs-chat). Those
# hostnames do not exist in the current docker-compose setup, so admin routes
# pointing at them will return 502 until the sidecars are deployed.
# CS_TICKETS_URL=http://cs-tickets:80
# CS_KB_URL=http://cs-kb:80
# CS_CHAT_URL=http://cs-chat:80

# Production / development. Affects error message verbosity in src/index.ts.
NODE_ENV=production
